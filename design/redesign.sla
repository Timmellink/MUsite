        <PAGEOBJECT XPOS="202.807816977045" YPOS="251.124565285443" OwnPage="0" ItemID="1007751641" PTYPE="4" WIDTH="302.192183022955" HEIGHT="142.719141776257" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L302.192 0 L302.192 142.719 L0 142.719 L0 0 Z" copath="M0 0 L302.192 0 L302.192 142.719 L0 142.719 L0 0 Z" gXpos="202.807816977045" gYpos="251.124565285443" gWidth="336.226634993937" gHeight="142.719141776257" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle LINESPMode="1" FONTSIZE="10"/>
                <ITEXT FONTSIZE="10" CH="Floorball is one of the fasted indoor sports in the world. We play year-round with always some members enthusiastic to play a game."/>
                <para LINESPMode="1"/>
                <para LINESPMode="1"/>
                <ITEXT FONTSIZE="10" CH="So, have you always enjoyed indoor hockey more than field hockey? Or would you like something new? Check out our training times and drop by! "/>
                <trail LINESPMode="1"/>
            </StoryText>
        </PAGEOBJECT>
